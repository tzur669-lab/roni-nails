rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Users
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    // Services — public read, admin write
    match /services/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Appointments (legacy flat collection — kept for backward compat during migration)
    match /appointments/{id} {
      allow get: if request.auth != null && (
        resource.data.clientId == request.auth.uid || isAdmin()
      );
      allow list: if true;
      allow create: if true;
      allow update: if request.auth != null && (
        resource.data.clientId == request.auth.uid || isAdmin()
      );
    }

    // ── appointmentsPending — pending + change_requested ────────────────────
    match /appointmentsPending/{id} {
      allow list:   if true;
      allow get:    if request.auth != null && (
        resource.data.clientId == request.auth.uid || isAdmin()
      );
      allow create: if true;
      allow update: if request.auth != null && (
        resource.data.clientId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── appointmentsApproved — upcoming approved bookings ───────────────────
    match /appointmentsApproved/{id} {
      allow list:  if true;
      allow get:   if request.auth != null && (
        resource.data.clientId == request.auth.uid || isAdmin()
      );
      allow write: if isAdmin();
    }

    // ── appointmentsRejected — rejected + cancelled bookings ────────────────
    match /appointmentsRejected/{id} {
      // list: authenticated users (needed for getClientAppointments to show
      //       a client's own cancelled appointments)
      allow list:  if request.auth != null;
      allow get:   if request.auth != null && (
        resource.data.clientId == request.auth.uid || isAdmin()
      );
      allow write: if isAdmin();
    }

    // ── appointmentsCompleted — past completed bookings ─────────────────────
    match /appointmentsCompleted/{id} {
      allow list:  if true;
      allow get:   if request.auth != null && (
        resource.data.clientId == request.auth.uid || isAdmin()
      );
      allow write: if isAdmin();
    }

    // Settings — public read, admin write
    match /availabilityRules/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /blockedTimes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /clinicSettings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /paymentSettings/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Client notes — admin only
    match /clientNotes/{id} {
      allow read, write: if isAdmin();
    }
  }
}
