rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Users
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    // Services — public read, admin write
    match /services/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Appointments (legacy flat collection — kept for backward compatibility during migration)
    match /appointments/{id} {
      allow get: if request.auth != null && (
        resource.data.clientId == request.auth.uid || isAdmin()
      );
      allow list: if true;
      allow create: if true;
      allow update: if request.auth != null && (
        resource.data.clientId == request.auth.uid || isAdmin()
      );
    }

    // Appointments — three collections by status (current architecture)

    // appointmentsPending — pending + change_requested bookings
    match /appointmentsPending/{id} {
      // List/query: public — needed for slot availability check by guests + clients
      allow list:   if true;
      // Single-doc read: only the owner or admin
      allow get:    if request.auth != null && (
        resource.data.clientId == request.auth.uid || isAdmin()
      );
      // Create: guests can book without login
      allow create: if true;
      // Update: owner (reschedule request) or admin (approve/reject)
      allow update: if request.auth != null && (
        resource.data.clientId == request.auth.uid || isAdmin()
      );
      // Delete: admin only — used in batch move when approving/rejecting
      allow delete: if isAdmin();
    }

    // appointmentsApproved — upcoming approved bookings
    match /appointmentsApproved/{id} {
      // List/query: public — needed for slot availability check
      allow list:   if true;
      // Single-doc read: owner or admin
      allow get:    if request.auth != null && (
        resource.data.clientId == request.auth.uid || isAdmin()
      );
      // All writes (create via batch move, update, delete/cancel): admin only
      allow write:  if isAdmin();
    }

    // appointmentsCompleted — past completed bookings (moved from appointmentsApproved)
    match /appointmentsCompleted/{id} {
      // List: any authenticated user (needed for getClientAppointments)
      allow list:   if request.auth != null;
      // Single-doc read: owner or admin
      allow get:    if request.auth != null && (
        resource.data.clientId == request.auth.uid || isAdmin()
      );
      // All writes: admin only
      allow write:  if isAdmin();
    }

    // appointmentsRejected — rejected + cancelled bookings
    match /appointmentsRejected/{id} {
      // List/query: admin only (no need to expose rejected slots publicly)
      allow list:   if isAdmin();
      // Single-doc read: owner or admin
      allow get:    if request.auth != null && (
        resource.data.clientId == request.auth.uid || isAdmin()
      );
      // All writes: admin only
      allow write:  if isAdmin();
    }

    // Settings — public read, admin write
    match /availabilityRules/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /blockedTimes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /clinicSettings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /paymentSettings/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Client notes — admin only
    match /clientNotes/{id} {
      allow read, write: if isAdmin();
    }
  }
}
